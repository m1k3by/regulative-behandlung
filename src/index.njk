<!DOCTYPE html>
<html lang="de">
<head>
  {% include "head.njk" %}
</head>
<body>

  {% include "header.njk" %}

  <!-- ═══════════════════════════════════════════════
       HERO – Martina-Foto mit Hover-Overlay
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Über Martina Stöcker">

    <div class="hero-photo">
      <div class="foto-wrapper">
        <img src="{{ site.hero_foto }}" alt="{{ site.hero_foto_alt }}" data-cms-image="hero-foto" />

        <div class="hero-overlay" aria-hidden="true">
          <p class="overlay-title">{{ site.hero_overlay_titel }}</p>
          <p class="overlay-body">{{ site.hero_overlay_text | replace("\n", "<br>") | safe }}</p>
          <span class="overlay-close">{{ site.hero_overlay_schluss }}</span>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="section-content">
        <img
          src="{{ site.hero_logo }}"
          alt="{{ site.hero_logo_alt }}"
          class="hero-logo"
          data-cms-image="hero-logo"
        />
      </div>
    </div>

  </section>

  <main>

    <!-- ═══════════════════════════════════════════════
         SEKTION 1 – Aktuelles (Slider + Kontaktformular)
    ════════════════════════════════════════════════ -->
    <section id="aktuelles" class="section">
      <div class="section-inner aktuelles-inner">
        <h2>Aktuelles</h2>

        <div class="section-content aktuelles-layout">

          <!-- ── Slider ──────────────────────────────── -->
          <div class="slider" aria-label="Aktuelle Beiträge">
            <div class="slider-track" id="sliderTrack">

              {% for slide in aktuelles.slides %}
              <article class="slide">
                <div class="slide-content">

                  {% if slide.kategorie %}
                  <div class="slide-infobox">
                    <p class="slide-category">{{ slide.kategorie }}</p>
                    <h3 class="slide-title">{{ slide.titel | safe }}</h3>
                    {% if slide.untertitel %}<p class="slide-subtitle">{{ slide.untertitel }}</p>{% endif %}
                    {% if slide.termin %}<p class="slide-meta">{{ slide.termin }}</p>{% endif %}
                    {% if slide.ort %}<p class="slide-address">{{ slide.ort }}</p>{% endif %}
                  </div>
                  {% endif %}

                  <img
                    src="{{ slide.bild }}"
                    alt="{{ slide.bild_alt }}"
                    class="slide-img"
                    data-cms-image="aktuelles-slide-{{ loop.index }}"
                  />

                  <div class="slide-beschreibung">
                    {{ slide.beschreibung | md | safe }}
                  </div>

                  {% if slide.kosten %}
                  <p class="slide-kosten"><strong>Kosten:</strong> {{ slide.kosten }}</p>
                  {% endif %}

                </div>
              </article>
              {% endfor %}

            </div><!-- /slider-track -->

            <button class="slider-btn slider-btn--prev" aria-label="Vorherige Folie">&#8249;</button>
            <button class="slider-btn slider-btn--next" aria-label="Nächste Folie">&#8250;</button>

            <div class="slider-dots" role="tablist" aria-label="Folien-Navigation">
              {% for slide in aktuelles.slides %}
              <button class="dot{% if loop.first %} dot--active{% endif %}"
                      data-index="{{ loop.index0 }}"
                      aria-label="Folie {{ loop.index }}"
                      role="tab"></button>
              {% endfor %}
            </div>

          </div><!-- /slider -->

          <!-- ── Kontaktformular (Formspree maqarkwd) ──── -->
          <aside class="aktuelles-kontakt">
            <h3 class="aktuelles-kontakt-titel">Kontakt</h3>
            <div class="form-erfolg" data-fs-success>
              <p>&#10003;&ensp;E-Mail versendet!</p>
              <p>Martina meldet sich bald bei Ihnen.</p>
            </div>
            <div class="form-fehler" data-fs-error></div>
            <form id="kontakt-form" class="kontakt-form">
              <div class="form-group">
                <label for="ak-name">Name <span class="form-required" aria-label="Pflichtfeld">*</span></label>
                <input type="text" id="ak-name" name="name" placeholder="Name" autocomplete="name" required data-fs-field />
                <span class="form-feld-fehler" data-fs-error="name"></span>
              </div>
              <div class="form-group">
                <label for="ak-email">E-Mail <span class="form-required" aria-label="Pflichtfeld">*</span></label>
                <input type="email" id="ak-email" name="email" placeholder="E-Mail" required autocomplete="email" data-fs-field />
                <span class="form-feld-fehler" data-fs-error="email"></span>
              </div>
              <div class="form-group">
                <label for="ak-nachricht">Nachricht <span class="form-required" aria-label="Pflichtfeld">*</span></label>
                <textarea id="ak-nachricht" name="nachricht" placeholder="Nachricht" rows="5" required data-fs-field></textarea>
                <span class="form-feld-fehler" data-fs-error="nachricht"></span>
              </div>
              <button type="submit" class="form-btn" data-fs-submit-btn>Senden</button>
            </form>
          </aside>

        </div><!-- /aktuelles-layout -->
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SEKTION 2 – regulative BeHANDlung ist …
    ════════════════════════════════════════════════ -->
    <section id="regulative" class="section section--parallax" aria-label="regulative BeHANDlung ist …">
      <div class="parallax-card">
        <div class="parallax-bg" aria-hidden="true"
             style="background-image: url('{{ regulative.parallax_bild }}');"></div>
        <div class="parallax-inner">
          <h2 class="parallax-titel">{{ regulative.titel }}</h2>
          <div class="parallax-cols">
            <div class="parallax-col">{{ regulative.spalte1 | md | safe }}</div>
            <div class="parallax-col">{{ regulative.spalte2 | md | safe }}</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SEKTION 2b + 2c – Zitate
    ════════════════════════════════════════════════ -->
    {% for zitat in zitate.zitate %}
    <section class="section section--zitat{% if zitat.stil == 'capra' %} section--capra{% endif %}"
             aria-label="Zitat {{ zitat.autor }}">
      <div class="zitat-inner" style="background-image: url('{{ zitat.hintergrund }}');">
        <blockquote class="zitat-block">
          <p class="zitat-text">{{ zitat.text | replace("\n", "<br>") | safe }}</p>
          <footer {% if zitat.stil == 'ortho' %}class="zitat-autor-wrapper"{% endif %}>
            {% if zitat.stil == 'ortho' %}
              <svg class="zitat-oval" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <ellipse class="zitat-oval-pfad"/>
              </svg>
            {% else %}
              <hr class="zitat-trennlinie" aria-hidden="true">
            {% endif %}
            <cite class="zitat-autor{% if zitat.stil == 'capra' %} zitat-autor--capra{% endif %}">{{ zitat.autor }}</cite>
          </footer>
        </blockquote>
      </div>
    </section>
    {% endfor %}

    <!-- ═══════════════════════════════════════════════
         SEKTION 3 – Information (Akkordeon)
    ════════════════════════════════════════════════ -->
    <section id="information" class="section">
      <div class="section-inner">
        <h2>Information</h2>
        <div class="section-content">

          <div class="akkordeon" role="list">

            {% for item in information.items %}
            <div class="akk-item" role="listitem">
              <button class="akk-kopf"
                      aria-expanded="{{ 'true' if item.offen else 'false' }}"
                      aria-controls="{{ item.id }}">
                <span>{{ item.titel }}</span>
                <svg class="akk-pfeil" aria-hidden="true" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="akk-inhalt" id="{{ item.id }}"{% if not item.offen %} hidden{% endif %}>
                <div class="akk-inhalt-inner">

                  {% if item.id == 'akk-kosten' %}
                    <p><strong>Kosten für Selbstzahler:</strong></p>
                    <table class="akk-tabelle">
                      <tbody>
                        {% for zeile in item.selbstzahler %}
                        <tr><td>{{ zeile.leistung }}</td><td>{{ zeile.preis }}</td></tr>
                        {% endfor %}
                      </tbody>
                    </table>
                    <p><strong>Kosten für Privat/Beihilfe/Zusatz-Versicherte:</strong></p>
                    <table class="akk-tabelle">
                      <tbody>
                        {% for zeile in item.privat %}
                        <tr><td>{{ zeile.leistung }}</td><td>{{ zeile.preis }}</td></tr>
                        {% endfor %}
                      </tbody>
                    </table>
                    <p>{{ item.kosten_hinweis }}</p>

                  {% elif item.id == 'akk-werkzeuge' %}
                    <ul class="akk-liste">
                      {% for w in item.werkzeuge %}
                      <li>{{ w }}</li>
                      {% endfor %}
                    </ul>

                  {% elif item.id == 'akk-weitere' %}
                    {{ item.inhalt | md | safe }}
                    <blockquote class="akk-zitat">
                      Ich kann sein, wie andere mich wollen,<br>
                      oder … ich kann sein, wie ich mich will,<br>
                      oder … ich bin die / der ICH BIN .
                    </blockquote>

                  {% else %}
                    {{ item.inhalt | md | safe }}
                  {% endif %}

                </div>
              </div>
            </div>
            {% endfor %}

          </div><!-- /akkordeon -->
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SEKTION 4 – Salz
    ════════════════════════════════════════════════ -->
    <section id="salz" class="section">
      <div class="section-inner">
        <h2>… Salz …</h2>
        <div class="section-content">

          <div class="salz-karten">
            {% for karte in salz.karten %}
            <div class="flip-karte" role="img" aria-label="{{ karte.aria_label }}">
              <div class="flip-karte-inner">
                <div class="flip-vorne">
                  <img src="{{ karte.bild }}" alt="{{ karte.bild_alt }}" data-cms-image>
                </div>
                <div class="flip-hinten">
                  <blockquote class="flip-zitat">
                    <p>{{ karte.zitat_text }}</p>
                    {% if karte.zitat_autor %}<footer><cite>{{ karte.zitat_autor }}</cite></footer>{% endif %}
                  </blockquote>
                </div>
              </div>
            </div>
            {% endfor %}
          </div><!-- /salz-karten -->

          <div class="salz-pdfs" role="list">
            {% for pdf in salz.pdfs %}
            <a class="pdf-btn" href="{{ pdf.datei }}" target="_blank" rel="noopener"
               aria-label="{{ pdf.aria }}" role="listitem">
              <svg class="pdf-icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
              {{ pdf.bezeichnung }}
            </a>
            {% endfor %}
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SEKTION 5 – Kontakt
    ════════════════════════════════════════════════ -->
    <section id="kontakt" class="section">
      <div class="section-inner">
        <h2>Kontakt</h2>
        <div class="section-content">

          <div class="kontakt-layout">

            <address class="kontakt-adresse">
              <p class="kontakt-name">{{ kontakt.name }}<br>
                <span>{{ kontakt.zusatz }}</span>
              </p>
              <p>
                <svg class="kontakt-icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {{ kontakt.strasse }}<br>
                <span class="kontakt-einzug">{{ kontakt.ort }}</span>
              </p>
              <p>
                <svg class="kontakt-icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.38 2 2 0 0 1 3.62 1.2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.8 16z"/></svg>
                <a href="tel:{{ kontakt.telefon_link }}">{{ kontakt.telefon_anzeige }}</a>
              </p>
              <p>
                <svg class="kontakt-icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:{{ kontakt.email }}">{{ kontakt.email }}</a>
              </p>
            </address>

            <div class="kontakt-karte-wrapper">
              <div class="kontakt-karte">
                <iframe
                  title="Karte: {{ kontakt.name }}, {{ kontakt.strasse }}, {{ kontakt.ort }}"
                  src="{{ kontakt.maps_embed }}"
                  width="100%" height="100%"
                  style="border:0;"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  allowfullscreen>
                </iframe>
              </div>
              <a class="kontakt-maps-link"
                 href="{{ kontakt.maps_link }}"
                 target="_blank" rel="noopener"
                 aria-label="Adresse in Google Maps öffnen">
                <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                In Google Maps öffnen
              </a>
            </div>

          </div><!-- /kontakt-layout -->

        </div>
      </div>
    </section>

  </main>

  {% include "footer.njk" %}

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Hero-Overlay Tap (Touch-Geräte)
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var wrapper = document.querySelector('.foto-wrapper');
      if (!wrapper) return;
      if (!window.matchMedia('(hover: none)').matches) return;
      wrapper.addEventListener('click', function () {
        wrapper.classList.toggle('overlay-aktiv');
      });
      document.addEventListener('click', function (e) {
        if (!wrapper.contains(e.target)) {
          wrapper.classList.remove('overlay-aktiv');
        }
      });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Burger-Menü
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var burger = document.querySelector('.burger');
      var nav    = document.getElementById('hauptNav');
      burger.addEventListener('click', function () {
        var istOffen = nav.classList.toggle('offen');
        burger.setAttribute('aria-expanded', istOffen ? 'true' : 'false');
        burger.setAttribute('aria-label', istOffen ? 'Menü schließen' : 'Menü öffnen');
      });
      nav.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          nav.classList.remove('offen');
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', 'Menü öffnen');
        });
      });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Slider
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var aktuellerSlide = 0;
      var track  = document.getElementById('sliderTrack');
      var dots   = document.querySelectorAll('.dot');
      var anzahl = document.querySelectorAll('.slide').length;

      function slideAktualisieren() {
        track.style.transform = 'translateX(-' + (aktuellerSlide * 100) + '%)';
        var aktiveSlide = track.querySelectorAll('.slide')[aktuellerSlide];
        if (aktiveSlide) { track.style.height = aktiveSlide.offsetHeight + 'px'; }
        dots.forEach(function (dot, i) {
          dot.classList.toggle('dot--active', i === aktuellerSlide);
          dot.setAttribute('aria-selected', i === aktuellerSlide ? 'true' : 'false');
        });
      }

      document.querySelector('.slider-btn--prev').addEventListener('click', function () {
        aktuellerSlide = (aktuellerSlide - 1 + anzahl) % anzahl;
        slideAktualisieren();
      });
      document.querySelector('.slider-btn--next').addEventListener('click', function () {
        aktuellerSlide = (aktuellerSlide + 1) % anzahl;
        slideAktualisieren();
      });
      dots.forEach(function (dot, i) {
        dot.addEventListener('click', function () { aktuellerSlide = i; slideAktualisieren(); });
      });
      window.addEventListener('load', slideAktualisieren);
      window.addEventListener('resize', slideAktualisieren);
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Aktiver Nav-Link beim Scrollen
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var navLinks  = document.querySelectorAll('.site-nav a[href^="#"]');
      var sektionen = document.querySelectorAll('main .section[id]');
      function navAktualisieren(aktiveId) {
        navLinks.forEach(function (link) {
          link.classList.toggle('aktiv', link.getAttribute('href') === '#' + aktiveId);
        });
      }
      var beobachter = new IntersectionObserver(function (eintraege) {
        eintraege.forEach(function (eintrag) {
          if (eintrag.isIntersecting) { navAktualisieren(eintrag.target.id); }
        });
      }, { rootMargin: '-72px 0px -55% 0px', threshold: 0 });
      sektionen.forEach(function (s) { beobachter.observe(s); });
      window.addEventListener('scroll', function () {
        if (window.scrollY < 80) { navLinks.forEach(function (l) { l.classList.remove('aktiv'); }); }
      }, { passive: true });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Parallax-Effekt
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var bg = document.querySelector('#regulative .parallax-bg');
      if (!bg) return;
      var ticking = false;
      function parallaxAktualisieren() {
        var sektion = bg.parentElement;
        var rect    = sektion.getBoundingClientRect();
        var viewH   = window.innerHeight;
        if (rect.bottom < 0 || rect.top > viewH) { ticking = false; return; }
        var fortschritt  = (viewH - rect.top) / (viewH + rect.height);
        var verschiebung = (fortschritt - 0.5) * 40;
        bg.style.transform = 'translateY(' + verschiebung + '%)';
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(parallaxAktualisieren); ticking = true; }
      }, { passive: true });
      window.addEventListener('resize', parallaxAktualisieren, { passive: true });
      parallaxAktualisieren();
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Akkordeon
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var buttons = document.querySelectorAll('.akk-kopf');
      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var offen = btn.getAttribute('aria-expanded') === 'true';
          buttons.forEach(function (b) {
            b.setAttribute('aria-expanded', 'false');
            var inhalt = document.getElementById(b.getAttribute('aria-controls'));
            if (inhalt) inhalt.hidden = true;
          });
          if (!offen) {
            btn.setAttribute('aria-expanded', 'true');
            var ziel = document.getElementById(btn.getAttribute('aria-controls'));
            if (ziel) ziel.hidden = false;
          }
        });
      });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT – Stift-Oval-Animation
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      var pfad  = document.querySelector('.zitat-oval-pfad');
      var svgEl = document.querySelector('.zitat-oval');
      var wrap  = document.querySelector('.zitat-autor-wrapper');
      if (!pfad || !svgEl || !wrap) return;
      function aufbauen() {
        var w = wrap.offsetWidth, h = wrap.offsetHeight;
        svgEl.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
        svgEl.setAttribute('width', w); svgEl.setAttribute('height', h);
        pfad.setAttribute('cx', w / 2); pfad.setAttribute('cy', h / 2);
        pfad.setAttribute('rx', w / 2 - 5); pfad.setAttribute('ry', h / 2 - 5);
        var len = pfad.getTotalLength(), overlap = len * 0.08, total = len + overlap;
        var styleEl = document.getElementById('oval-anim-kf');
        if (!styleEl) { styleEl = document.createElement('style'); styleEl.id = 'oval-anim-kf'; document.head.appendChild(styleEl); }
        styleEl.textContent =
          '@keyframes stift-oval-dyn {\n' +
          '  0%  { stroke-dashoffset: ' +  total    + '; opacity: 1; }\n' +
          '  5%  { stroke-dashoffset: ' +  total    + '; opacity: 1; }\n' +
          '  60% { stroke-dashoffset: ' + (-overlap) + '; opacity: 1; }\n' +
          '  74% { stroke-dashoffset: ' + (-overlap) + '; opacity: 1; }\n' +
          '  90% { stroke-dashoffset: ' + (-overlap) + '; opacity: 0; }\n' +
          ' 100% { stroke-dashoffset: ' +  total    + '; opacity: 0; }\n}';
        pfad.style.strokeDasharray  = total;
        pfad.style.strokeDashoffset = total;
        pfad.style.animation = 'none';
        void pfad.getBoundingClientRect();
        pfad.style.animation = 'stift-oval-dyn 5s ease-out infinite';
      }
      window.addEventListener('load', aufbauen);
      window.addEventListener('resize', aufbauen, { passive: true });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════
       Formspree AJAX-Bibliothek
  ════════════════════════════════════════════════ -->
  <script>
    window.formspree = window.formspree || function () {
      (formspree.q = formspree.q || []).push(arguments);
    };
    formspree('initForm', { formElement: '#kontakt-form', formId: 'maqarkwd' });
  </script>
  <script src="https://unpkg.com/@formspree/ajax@1" defer></script>

</body>
</html>
